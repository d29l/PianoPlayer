<Window x:Class="MidiToKeyboardApp.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Mini Player"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1e1e2e"
        Topmost="True"
        AllowsTransparency="False">

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f38ba8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="28"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="MainBorder" BorderThickness="1" BorderBrush="#313244">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="140"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#181825" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Column="0"
                           Text="Mini Player"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#cdd6f4"/>

                <!-- Window Control Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Pin/Unpin Button -->
                    <Button x:Name="PinButton"
                            Click="PinButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Toggle Always On Top">
                        <Path x:Name="PinIcon"
                              Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"
                              Fill="#cdd6f4"
                              Stretch="Uniform"
                              Width="14"
                              Height="14"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Minimize Button -->
                    <Button x:Name="MinimizeButton"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="M0,0 L8,0"
                              Stroke="#cdd6f4"
                              StrokeThickness="1"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="M0,0 L8,8 M8,0 L0,8"
                              Stroke="#cdd6f4"
                              StrokeThickness="1"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Piano Roll Section -->
            <Border Grid.Row="1"
                    Background="#181825"
                    Margin="6,6,6,3"
                    CornerRadius="6"
                    BorderBrush="#313244"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Piano Roll Header -->
                    <Border Grid.Row="0"
                            Background="#11111b"
                            CornerRadius="6,6,0,0"
                            Padding="6,3">
                        <TextBlock Text="Piano Roll"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#a6adc8"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- WebView for Piano Roll -->
                    <wv2:WebView2 Name="pianoRollWebView"
                                  Grid.Row="1"
                                  Margin="0"
                                  DefaultBackgroundColor="#181825"/>
                </Grid>
            </Border>

            <!-- Now Playing / Upcoming Notes Display -->
            <Border Grid.Row="2"
                    Background="#181825"
                    Margin="6,3,6,3"
                    CornerRadius="6"
                    BorderBrush="#313244"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="#11111b"
                            CornerRadius="6,6,0,0"
                            Padding="6,3">
                        <TextBlock Text="Now Playing"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#a6adc8"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Scrolling Music Display -->
                    <ScrollViewer x:Name="MusicDisplayScrollViewer"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="10,8">
                        <TextBlock x:Name="MusicDisplay"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#cdd6f4"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center"
                                   Text="(No music loaded)"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Player Controls Section -->
    <Border Grid.Row="3"
            Background="#181825"
            Margin="6,3,6,6"
            CornerRadius="6"
            BorderBrush="#313244"
            BorderThickness="1"
            Padding="10,8,10,6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Now Playing Title -->
            <TextBlock x:Name="NowPlayingTitle"
                       Grid.Row="0"
                       Text="Untitled"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#cdd6f4"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"/>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,0">

                        <!-- Skip Back Button -->
                        <Button x:Name="SkipBackBtn"
                                Width="40"
                                Height="40"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="0,0,6,0"
                                Click="SkipBackBtn_Click"
                                ToolTip="Skip to start"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="20">
                                        <Path Data="M19 20L9 12L19 4V20M7 4V20H5V4H7Z"
                                              Fill="#cdd6f4"
                                              Stretch="Uniform"
                                              Width="20"
                                              Height="20"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Play/Pause Button -->
                        <Button x:Name="PlayPauseBtn"
                                Width="48"
                                Height="48"
                                Background="White"
                                BorderThickness="0"
                                Margin="0,0,6,0"
                                Click="PlayPauseBtn_Click"
                                ToolTip="Play/Pause"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="24">
                                        <Grid>
                                            <!-- Play Icon -->
                                            <Path x:Name="PlayIcon"
                                                  Data="M5 3L19 12L5 21V3Z"
                                                  Fill="#1e1e2e"
                                                  Stretch="Uniform"
                                                  Width="24"
                                                  Height="24"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                            <!-- Pause Icon -->
                                            <Path x:Name="PauseIcon"
                                                  Data="M6 4H10V20H6V4M14 4H18V20H14V4Z"
                                                  Fill="#1e1e2e"
                                                  Stretch="Uniform"
                                                  Width="24"
                                                  Height="24"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#f5f5f5"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Stop Button -->
                        <Button x:Name="StopBtn"
                                Width="40"
                                Height="40"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="StopBtn_Click"
                                ToolTip="Stop"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="20">
                                        <Path Data="M3 3H21V21H3V3Z"
                                              Fill="#cdd6f4"
                                              Stretch="Uniform"
                                              Width="20"
                                              Height="20"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Progress Bar -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Progress Bar -->
                        <Border Grid.Row="0"
                                Background="#313244"
                                Height="4"
                                CornerRadius="2"
                                Margin="0">
                            <Border x:Name="ProgressFill"
                                    Background="#89b4fa"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Width="0"/>
                        </Border>

                        <!-- Time Display with Progress Info -->
                        <TextBlock Grid.Row="1"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0">
                            <Run Text="Note "
                                 FontSize="9"
                                 Foreground="#7f849c"/>
                            <Run x:Name="CurrentTimeText"
                                 Text="0"
                                 FontSize="9"
                                 FontWeight="SemiBold"
                                 Foreground="#89b4fa"/>
                            <Run Text=" / "
                                 FontSize="9"
                                 Foreground="#7f849c"/>
                            <Run x:Name="TotalTimeText"
                                 Text="0"
                                 FontSize="9"
                                 FontWeight="SemiBold"
                                 Foreground="#cdd6f4"/>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
